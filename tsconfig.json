{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "src/app/grocery_17/page.jsx",
    "src/app/grocery_17/_components/Form_17.jsx",
    "src/app/grocery_17/_components/Items_17.jsx",
    "src/app/grocery_17/_components/SingleItem_17.jsx",
    "src/app/grocery_db_17/_components/SingleItem_17.tsx",
    "src/app/grocery_db_17/_components/Items_17.tsx",
    "src/app/grocery_db_17/_components/Form_17.tsx",
    "src/actions/blog.action_17.tss"
  ],
  "exclude": ["node_modules"]
}
